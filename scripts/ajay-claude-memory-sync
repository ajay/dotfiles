#!/usr/bin/env bash
# Sync Claude Code memory via the private dotfiles submodule.
# Pulls newest memory from the other machines, commits + pushes any local
# changes, then bumps the superproject pointer. Run on a machine WITH SSH
# (Claude's agent shell has no SSH keys, so it cannot run this).
set -euo pipefail

SUPER="$HOME/.dotfiles"
SUB="$SUPER/private"

# 1) Pull newest memory (rebase local commits on top; stash any in-flight edits).
git -C "$SUB" pull --rebase --autostash origin main

# 2) Pre-push secret scan (high-signal patterns) — abort rather than leak.
if grep -rniE '(-----BEGIN [A-Z ]*PRIVATE KEY|ghp_[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16}|aws_secret|client_secret)' "$SUB/dotfiles/claude" >/dev/null 2>&1; then
  echo "ABORT: possible secret detected under $SUB/dotfiles/claude — review before syncing." >&2
  exit 1
fi

# 3) Commit + push local memory changes in the submodule.
if [ -n "$(git -C "$SUB" status --porcelain)" ]; then
  git -C "$SUB" add -A
  git -C "$SUB" commit -m "claude: memory update from $(hostname -s) $(date +%F)"
  git -C "$SUB" push origin main
fi

# 4) Bump the superproject submodule pointer.
if [ -n "$(git -C "$SUPER" status --porcelain -- private)" ]; then
  git -C "$SUPER" add private
  git -C "$SUPER" commit -m "claude: bump private memory submodule"
  git -C "$SUPER" push origin master
fi

echo "claude memory sync: done."
