#!/usr/bin/env bash
# Sync the private dotfiles submodule (git@github.com:ajay/dotfiles-private.git):
# pull the newest state from other machines, commit + push local changes, then
# bump the superproject pointer. Run on a machine WITH SSH — Claude's agent shell
# has no SSH keys, so it cannot run this.
set -euo pipefail

SUPER="$HOME/.dotfiles"
SUB="$SUPER/private"
SUB_BRANCH="$(git -C "$SUPER" config -f .gitmodules submodule.private.branch || echo main)"
SUPER_BRANCH="$(git -C "$SUPER" rev-parse --abbrev-ref HEAD)"

# git submodule update can leave the submodule on a detached HEAD; attach to its
# branch first, else any commit we make here would be orphaned (never pushed).
git -C "$SUB" checkout "$SUB_BRANCH"

# 1) Pull newest (rebase local commits on top; stash in-flight edits). On conflict,
#    stop so it can be resolved by hand.
if ! git -C "$SUB" pull --rebase --autostash origin "$SUB_BRANCH"; then
  echo "ABORT: pull into $SUB hit conflicts — resolve in $SUB, finish the rebase, then re-run." >&2
  exit 1
fi

# 2) Pre-push secret scan (high-signal patterns) — abort rather than leak.
if grep -rniE --exclude-dir=.git \
    '(-----BEGIN [A-Z ]*PRIVATE KEY|ghp_[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16}|aws_secret|client_secret)' \
    "$SUB" >/dev/null 2>&1; then
  echo "ABORT: possible secret detected under $SUB — review before syncing." >&2
  exit 1
fi

# 3) Commit + push local changes in the submodule.
if [ -n "$(git -C "$SUB" status --porcelain)" ]; then
  git -C "$SUB" add -A
  git -C "$SUB" commit -m "sync from $(hostname -s) $(date +%F)"
  git -C "$SUB" push origin "$SUB_BRANCH"
fi

# 4) Bump the superproject submodule pointer.
if [ -n "$(git -C "$SUPER" status --porcelain -- private)" ]; then
  git -C "$SUPER" add private
  git -C "$SUPER" commit -m "private: bump submodule pointer"
  git -C "$SUPER" push origin "$SUPER_BRANCH"
fi

echo "dotfiles-private sync: done."
